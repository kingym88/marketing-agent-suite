# ==============================================================================
# SECURITY WARNING: NEVER commit your actual .env file to version control!
# If deploying to production, rely strictly on secure secret managers 
# (e.g., HashiCorp Vault, AWS Secrets Manager, or Railway Environment Variables).
# Ensure .env is listed in .gitignore.
# ==============================================================================

# Perplexity API Configuration
# [REQUIRED]: Add a scoped, read-only API key mapped explicitly to your tenant.
# Rotate this key every 90 days.
PERPLEXITY_API_KEY=your_pplx_api_key_here

# Server Configuration
# [OPTIONAL]: Define the port the server listens on (default 3000)
PORT=3000

# Security Defaults
# [OPTIONAL]: Define strict CORS origin explicitly (e.g. http://localhost:3000)
ALLOWED_ORIGIN=http://localhost:3000
